<view class="me-page">
  <view class="header">
    <text class="nickname">{{userInfo.nickname || '商户用户'}}</text>
  </view>
  <view class="menu-list">
    <view class="menu-item" bindtap="goToCards">
      <text>信用卡管理</text><text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToUpload">
      <text>数据导入</text><text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToPurchase">
      <text>进货规划</text><text class="arrow">></text>
    </view>
  </view>
  <view class="menu-list">
    <view class="menu-item" bindtap="logout">
      <text class="logout-text">退出登录</text>
    </view>
  </view>
</view>
