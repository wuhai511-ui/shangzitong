.calendar-page { padding: 16rpx; background: #f5f5f5; min-height: 100vh; }
.summary-bar { display: flex; background: white; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; }
.summary-item { flex: 1; text-align: center; }
.label { font-size: 24rpx; color: #999; }
.value { font-size: 36rpx; font-weight: bold; margin-top: 8rpx; display: block; }
.green { color: #07c160; } .red { color: #e74c3c; }
.calendar-scroll { white-space: nowrap; margin-bottom: 16rpx; }
.day-card { display: inline-block; width: 160rpx; background: white; border-radius: 12rpx; padding: 16rpx; margin-right: 8rpx; vertical-align: top; }
.day-card.alert { border: 2rpx solid #e74c3c; }
.day-date { font-size: 26rpx; color: #666; }
.event { display: block; font-size: 22rpx; margin-top: 4rpx; }
.settlement { color: #07c160; } .repayment { color: #e74c3c; }
.alert-tag { position: absolute; top: 4rpx; right: 8rpx; color: #e74c3c; font-weight: bold; }
.chart-area { background: white; border-radius: 16rpx; padding: 16rpx; }
.pool-chart { width: 100%; height: 300rpx; }
